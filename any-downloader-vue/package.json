{
  "name": "any-downloader-vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AnyDownloader — Vue UI + optional Electron shell",
  "author": "AnyDownloader",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/gen-app-icon.cjs",
    "build": "vue-tsc -b && vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "fetch:aria2": "node scripts/fetch-aria2-win.cjs",
    "fetch:ytdlp": "node scripts/fetch-ytdlp-win.cjs",
    "electron:pack": "node scripts/clean-release.cjs && node scripts/fetch-aria2-win.cjs && node scripts/fetch-ytdlp-win.cjs && npm run build && electron-builder --dir",
    "electron:dist": "node scripts/clean-release.cjs && node scripts/fetch-aria2-win.cjs && node scripts/fetch-ytdlp-win.cjs && npm run build && electron-builder"
  },
  "dependencies": {
    "parse-torrent": "^11.0.19",
    "path-browserify": "^1.0.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "adm-zip": "^0.5.17",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.anydownloader.vue",
    "productName": "AnyDownloader",
    "copyright": "Copyright © 2026 AnyDownloader",
    "icon": "build-resources/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs",
      "build-resources/icon.png",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "build-resources/aria2",
          "to": "aria2",
          "filter": [
            "aria2c.exe",
            "COPYING",
            "README.md"
          ]
        },
        {
          "from": "build-resources/yt-dlp",
          "to": "yt-dlp",
          "filter": [
            "yt-dlp.exe",
            "README.md"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "AnyDownloader <noreply@localhost>",
      "synopsis": "Universal download manager UI"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
